{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Delivery",
  "type": "object",
  "required": [
    "id",
    "project_id",
    "task_id",
    "agent_id",
    "summary",
    "files_changed",
    "verification",
    "followups",
    "status"
  ],
  "properties": {
    "id": { "type": "string" },
    "project_id": { "type": "string" },
    "task_id": { "type": "string" },
    "agent_id": { "type": "string" },
    "context_snapshot_id": { "type": ["string", "null"] },
    "context_steward_id": { "type": "string" },
    "summary": { "type": "string" },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verification": {
      "type": "array",
      "items": { "type": "string" }
    },
    "followups": {
      "type": "array"
    },
    "ai_detection": {
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "summary": { "type": "string" },
        "findings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "review": {
      "type": "object",
      "properties": {
        "decision": { "type": "string" },
        "reviewed_by": { "type": "string" },
        "reviewed_at": { "type": "string" },
        "context_steward_id": { "type": "string" },
        "method": { "type": "string" },
        "summary": { "type": "string" },
        "context_update": { "type": "string" },
        "ai_detection": {
          "type": "object",
          "properties": {
            "status": { "type": "string" },
            "summary": { "type": "string" },
            "findings": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["submitted", "accepted", "rejected"]
    }
  }
}
