{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProjectOwnerReport",
  "type": "object",
  "required": [
    "id",
    "project_id",
    "thread_id",
    "health",
    "summary",
    "progress",
    "risks",
    "blockers",
    "next_actions",
    "proposed_tasks",
    "answered_at",
    "created_at"
  ],
  "properties": {
    "id": { "type": "string" },
    "project_id": { "type": "string" },
    "thread_id": { "type": "string" },
    "thread_name": { "type": "string" },
    "health": {
      "type": "string",
      "enum": ["on_track", "at_risk", "blocked", "paused", "done"]
    },
    "summary": { "type": "string" },
    "context": {
      "type": ["object", "null"],
      "properties": {
        "summary": { "type": "string" },
        "requirements": {
          "type": "object",
          "properties": {
            "p0": {
              "type": "array",
              "items": { "type": "string" }
            },
            "p1": {
              "type": "array",
              "items": { "type": "string" }
            },
            "p2": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "updated_at": { "type": "string" }
      }
    },
    "progress": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "proposed_tasks": { "type": "array" },
    "asked_at": {
      "type": ["string", "null"]
    },
    "answered_at": { "type": "string" },
    "created_at": { "type": "string" }
  }
}
