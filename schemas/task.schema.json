{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task",
  "type": "object",
  "required": [
    "id",
    "project_id",
    "title",
    "objective",
    "status",
    "context_status"
  ],
  "properties": {
    "id": { "type": "string" },
    "project_id": { "type": "string" },
    "title": { "type": "string" },
    "objective": { "type": "string" },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "urgent"]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "claimed",
        "in_progress",
        "review",
        "done",
        "blocked"
      ]
    },
    "context_status": {
      "type": "string",
      "enum": ["missing", "ready", "stale"]
    },
    "context_snapshot_id": {
      "type": ["string", "null"]
    },
    "required_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assigned_agent_id": {
      "type": ["string", "null"]
    }
  }
}
