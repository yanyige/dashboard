{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task",
  "type": "object",
  "required": [
    "id",
    "project_id",
    "title",
    "objective",
    "status",
    "context_status"
  ],
  "properties": {
    "id": { "type": "string" },
    "project_id": { "type": "string" },
    "title": { "type": "string" },
    "objective": { "type": "string" },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "urgent"]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "claimed",
        "in_progress",
        "review",
        "done",
        "rejected",
        "blocked"
      ]
    },
    "context_status": {
      "type": "string",
      "enum": ["missing", "ready", "stale"]
    },
    "context_snapshot_id": {
      "type": ["string", "null"]
    },
    "project_owner_thread_id": {
      "type": ["string", "null"]
    },
    "owner_report_id": {
      "type": ["string", "null"]
    },
    "required_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "parallel_group": {
      "type": "string"
    },
    "assigned_agent_id": {
      "type": ["string", "null"]
    },
    "agent_acceptance": {
      "type": ["object", "null"],
      "properties": {
        "agent_id": { "type": "string" },
        "accepted_at": { "type": "string" },
        "note": { "type": "string" },
        "plan": { "type": "string" },
        "eta": { "type": "string" },
        "next_report_at": { "type": "string" }
      }
    }
  }
}
